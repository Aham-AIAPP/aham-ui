    "color": { "$value": "currentColor", "$description": "继承文字色(ink token);不加品牌色。状态图标须配文字(守不靠颜色单独传达)" },
    "weight": { "$value": "single", "$description": "Lucide 单字重;若需随相邻文字字重变化(↔SF Symbols)走 SF/Phosphor,后续" },
    "manifest": { "$value": "icons/icons.json", "$description": "语义名 → Lucide 名映射(51 起始件),含 sfSymbol 预留列" },
