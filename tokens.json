{
  "$meta": {
    "name": "Aham UI",
    "version": "5.1.0",
    "basis": "Claude desktop temperament — minimal, restrained, whitespace-first",
    "lineage": "Regularized from the Aham Workbench design system. Two changes: accent terracotta → blue #336EE8; fonts unified to one sans (Inter + YaHei/SimHei) + mono, serif dropped; CJK fallback added. All other values faithful to Workbench.",
    "principles": [
      "necessity first (default is don't-add)",
      "blue is a garnish not a fill",
      "hierarchy from background tiers + whitespace, never shadow/color",
      "status = symbol + color dual channel, never a block",
      "flat — no resting shadows"
    ],
    "note": "v5.1: 清理 15 个旧/重复类(8 个与 text-* 重复的旧排版类 t-* 迁移后删除、7 个死代码类 review/checklist/avatar/num-input/frow/fsection/wrap-pad)。v5.0: 对照 Apple HIG 完整性审计补全 30 项。v4.0: 以 Apple HIG 框架重构。"
  },
  "color": {
    "surface": {
      "$description": "Three tiers only. Neutral, no warm cast.",
      "tier1-white": {
        "$value": "#FFFFFF",
        "$description": "content / cards / inputs / document"
      },
      "tier2-panel": {
        "$value": "#F3F3F3",
        "$description": "secondary bg / sidebar / sunken / region block"
      },
      "tier3-line": {
        "$value": "#E7E7E7",
        "$description": "divider / border / disabled / selected"
      }
    },
    "ink": {
