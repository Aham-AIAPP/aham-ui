        "$value": "#336EE8"
      },
      "hover": {
        "$value": "#5C8BED"
      },
      "press": {
        "$value": "#164EC3"
      },
      "tint-border": {
        "$value": "#C8D3EA",
        "$description": "almost never used"
      },
      "tint-surface": {
        "$value": "#EDF0F7",
        "$description": "almost never used"
      }
    },
    "semantic": {
      "$description": "Heavily muted, genuine-risk only. The rare exception. Status is otherwise monochrome.",
