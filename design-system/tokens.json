    "source": { "$value": "Lucide", "$description": "lucide-static 1.24.0 · ISC · 原始 SVG 存 icons/lucide/,LICENSE 已保留" },
    "license": { "$value": "ISC" },
    "grid": { "$value": "24", "$description": "设计网格 viewBox 0 0 24 24" },
    "strokeWidth": { "$value": "2", "$description": "Lucide 原生 2px@24;有效描边随尺寸缩放:16px≈1.3 / 20px≈1.7 / 24px=2。需更轻用 1.5(.icon--thin)" },
